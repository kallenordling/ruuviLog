<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textMac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <TextView
            android:id="@+id/textFormat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="10dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4">

            <!-- Temperature -->
            <TextView android:text="🌡 Temperature"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/textTemperature"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <!-- Humidity -->
            <TextView android:text="💧 Humidity"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/textHumidity"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <!-- Pressure -->
            <TextView android:text="🔵 Pressure"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/textPressure"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <!-- Battery -->
            <TextView android:text="🔋 Battery"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/textBattery"
                android:layout_width="0dp" android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

        </GridLayout>

        <!-- Acceleration full-width -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView android:text="📐 Accel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/textAccel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Movement / Sequence -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView android:text="Move: "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"/>
            <TextView android:id="@+id/textMovement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"/>
            <TextView android:text="Seq: "
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"/>
            <TextView android:id="@+id/textSequence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
